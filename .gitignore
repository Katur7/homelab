# Secrets and Environments
# Only ignore files named exactly '.env' — vars.env and global.env are tracked
.env

# OS generated files
.DS_Store
.Thumbs.db

# Docker Data
volumes/

# Service state (runtime data, gitignored — covered by BorgBackup)
/services/mealie/data/
/services/calibre-web/config/
/services/plex/config/
/services/starr/radarr-config/
/services/starr/sonarr-config/
/services/starr/prowlarr-config/
/services/starr/qbittorrent-config/
/services/syncthing/config/
/services/vikunja/files/
/services/vikunja/db/
/services/audiobookshelf/config/
/services/audiobookshelf/metadata/
/services/home-assistant/config/*
!/services/home-assistant/config/configuration.yaml
!/services/home-assistant/config/sensors/
!/services/home-assistant/config/templates/
/services/home-assistant/matter-server/
/services/immich/database/
/services/linguacafe/database/
/services/linguacafe/storage/

# Gateway — sensitive runtime files only (most config IS git-tracked)
/infrastructure/gateway/config/acme.json
/infrastructure/gateway/config/authelia/db.sqlite3
/infrastructure/gateway/config/authelia/notification.txt
/infrastructure/gateway/config/authelia/secrets/
/infrastructure/gateway/config/authelia/users_database.yml
/infrastructure/gateway/config/dynamic/crowdsec.yml
/infrastructure/gateway/logs/

# CrowdSec — hub-managed files (auto-downloaded at startup, not our config)
/infrastructure/gateway/config/crowdsec/hub/
/infrastructure/gateway/config/crowdsec/collections/
/infrastructure/gateway/config/crowdsec/parsers/
/infrastructure/gateway/config/crowdsec/scenarios/
/infrastructure/gateway/config/crowdsec/postoverflows/
/infrastructure/gateway/config/crowdsec/contexts/
/infrastructure/gateway/config/crowdsec/patterns/
/infrastructure/gateway/config/crowdsec/appsec-configs/
/infrastructure/gateway/config/crowdsec/appsec-rules/
# CrowdSec — runtime credentials (auto-generated, contain API keys)
/infrastructure/gateway/config/crowdsec/local_api_credentials.yaml
/infrastructure/gateway/config/crowdsec/online_api_credentials.yaml

# PiHole — entire config volume is runtime state (gravity.db, pihole.toml, logs, etc.)
/infrastructure/dns/config/

# Tailscale — binary runtime state
/infrastructure/tailscale/state/

# WireGuard — server + peer private keys (auto-generated on first run)
/infrastructure/wireguard/config/

# Pi — service runtime data
/pi/services/pihole/data/
/pi/services/uptime-kuma/data/

# IDE files
.vscode/
.idea/