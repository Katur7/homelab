# Cloudflare stack — non-sensitive configuration
# Git-tracked. Secrets go in .env (git-ignored).
#
# PUID, PGID, TZ are inherited from ../../global.env.

# ── cloudflare-ddns ───────────────────────────────────────────────────────────
# Mapped from /appdata/cloudflare/ddns-config.json
# CLOUDFLARE_API_TOKEN is in .env (git-ignored)
IP4_PROVIDER=cloudflare.trace
IP4_DOMAINS=vpn.pippinn.me
IP6_PROVIDER=none
PROXIED=false
TTL=600
