# WUD — non-sensitive configuration
# Git-tracked. Secrets go in .env (git-ignored).

WUD_REGISTRY_LSCR_PRIVATE_USERNAME=Katur7
WUD_WATCHER_PROXY_HOST=http://socket-proxy:2375
WUD_WATCHER_PROXY_CRON=0 1 * * *

# Auto-update webhook trigger — fires for containers labelled wud.trigger.include=http.autoupdate
# THRESHOLD=minor: belt-and-suspenders against major version jumps (listener also checks)
WUD_TRIGGER_HTTP_AUTOUPDATE_URL=http://autoupdater:8080
WUD_TRIGGER_HTTP_AUTOUPDATE_METHOD=POST
WUD_TRIGGER_HTTP_AUTOUPDATE_THRESHOLD=minor
