# PiHole admin password — used by nebula-sync to authenticate to both PiHole instances.
# Both the NAS and Pi PiHole must share the same admin password for sync to work.
PIHOLE_PASSWORD=your_pihole_admin_password
# Use direct IP to avoid having to configure dns
UPTIME_PUSH_URL=http://192.168.86.26:3001/api/push/token?status=up&msg=OK&ping=
