# PiHole — Pi-specific identity settings
# These are unique to this host and intentionally NOT synced by Nebula-Sync.
FTLCONF_dns_reply_host_IPv4=192.168.86.26
FTLCONF_webserver_domain=pihole-on-pi.internal.pippinn.me
FTLCONF_dns_listeningMode=all

# SD card protection — store FTL query database in RAM, not on disk.
# Query history is lost on reboot, which is acceptable for a backup PiHole.
FTLCONF_files_database=/ftl-db/pihole-FTL.db
FTLCONF_misc_privacylevel=3

# Wildcard DNS — all *.internal.pippinn.me resolves to the NAS/Traefik gateway.
# Set here instead of synced via nebula-sync (SYNC_CONFIG_MISC=false) to avoid
# conflict with env-locked misc.privacylevel.
FTLCONF_misc_dnsmasq_lines=address=/.internal.pippinn.me/192.168.86.17
